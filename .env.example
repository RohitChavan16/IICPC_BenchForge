# =========================================================
# IICPC BenchForge Environment Configuration Reference
# =========================================================
#
# Welcome to the BenchForge configuration template. 
# This file serves as a centralized reference for configuring 
# the microservices in local, staging, and production environments.
#
# IMPORTANT SECURITY NOTES:
# 1. DO NOT commit actual .env files containing production secrets.
# 2. Use strong, randomly generated passwords for database connections.
# 3. Restrict database host exposure in production.
#
# USAGE:
# Each microservice maintains its own `.env` file (e.g., `services/bot-worker/.env`).
# Copy relevant sections from this template to the respective service directories.
# =========================================================

# =========================================================
# API GATEWAY
# File: services/api-gateway/.env
# =========================================================

# [REQUIRED] Redis connection string for telemetry event streaming
# Example: redis:6379 (Docker internal) or localhost:6379 (Local dev)
REDIS_URL=redis:6379

# [REQUIRED] PostgreSQL connection string for metrics and system data
# Example: postgres://user:password@host:port/dbname
POSTGRES_URL=postgres://postgres:password@postgres:5432/iicpc

# [REQUIRED] The port the API Gateway binds to
API_GATEWAY_PORT=8080

# [OPTIONAL] Log Level (debug, info, warn, error)
LOG_LEVEL=info

# =========================================================
# TELEMETRY SERVICE
# File: services/telemetry-service/.env
# =========================================================

# [REQUIRED] Redis connection string (used for consuming telemetry streams)
REDIS_URL=redis:6379

# [REQUIRED] PostgreSQL connection string (used for persisting aggregated metrics)
POSTGRES_URL=postgres://postgres:password@postgres:5432/iicpc

# [REQUIRED] The port the Telemetry Service binds to
TELEMETRY_PORT=8081

# [OPTIONAL] Redis Consumer Group ID
CONSUMER_GROUP=telemetry_group

# =========================================================
# BOT WORKER (LOAD GENERATOR)
# File: services/bot-worker/.env
# =========================================================

# [REQUIRED] Redis connection string (used for publishing latency events)
REDIS_URL=redis:6379

# [REQUIRED] PostgreSQL connection string
POSTGRES_URL=postgres://postgres:password@postgres:5432/iicpc

# [REQUIRED] The target exchange URL that the bots will hammer
TARGET_EXCHANGE_URL=http://mock-exchange:9000

# [OPTIONAL] Maximum concurrent goroutines per worker node
MAX_CONCURRENCY=10000

# =========================================================
# MOCK EXCHANGE
# File: services/mock-exchange/.env
# =========================================================

# [REQUIRED] Redis connection string
REDIS_URL=redis:6379

# [REQUIRED] PostgreSQL connection string
POSTGRES_URL=postgres://postgres:password@postgres:5432/iicpc

# [REQUIRED] The port the Mock Exchange binds to
MOCK_EXCHANGE_PORT=9000

# [OPTIONAL] Simulated latency (in milliseconds) to inject artificially
ARTIFICIAL_LATENCY_MS=0