# =========================================================
# IICPC BenchForge Environment Configuration Reference
# =========================================================

# NOTE:
# Each microservice maintains its own `.env` file.
#
# Example:
#
# services/api-gateway/.env
# services/telemetry-service/.env
# services/bot-worker/.env
# services/mock-exchange/.env
#
# This file serves as a centralized configuration reference.
# =========================================================



# =========================================================
# API GATEWAY
# File:
# services/api-gateway/.env
# =========================================================

# Redis
REDIS_URL=redis:6379

# PostgreSQL
POSTGRES_URL=postgres://postgres:password@postgres:5432/iicpc

# Ports
API_GATEWAY_PORT=8080
TELEMETRY_PORT=8081
MOCK_EXCHANGE_PORT=9000



# =========================================================
# TELEMETRY SERVICE
# File:
# services/telemetry-service/.env
# =========================================================
# Redis
REDIS_URL=redis:6379

# PostgreSQL
POSTGRES_URL=postgres://postgres:password@postgres:5432/iicpc

# Ports
API_GATEWAY_PORT=8080
TELEMETRY_PORT=8081
MOCK_EXCHANGE_PORT=9000



